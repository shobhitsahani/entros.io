NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001/verify
NEXT_PUBLIC_RELAYER_API_KEY=
NEXT_PUBLIC_WASM_URL=/circuits/entros_hamming.wasm
NEXT_PUBLIC_ZKEY_URL=/circuits/entros_hamming_final.zkey

# Server-only allowlist for the /embed/verify-popup route.
# Map of integrator keys to allowed parent origins. Strict equality match.
# Dev mode allows any integrator key against http://localhost(:port) regardless of this config.
ENTROS_INTEGRATORS_JSON={"jupiter":{"origins":["https://jup.ag"]},"drift":{"origins":["https://app.drift.trade"]}}
